@model ASPNetDashboard.Models.LoginViewModel
@{ Layout = null; ViewData["Title"] = "Login"; }

<!DOCTYPE html>
<html lang="en" data-bs-theme="light">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Login — Student System</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />

    <!-- Apply saved theme BEFORE render to prevent flash -->
    <script>
        (function () {
            var t = localStorage.getItem('theme') || 'light';
            document.documentElement.setAttribute('data-bs-theme', t);
        })();
    </script>
</head>
<body>

<div class="container">
    <div class="row justify-content-center align-items-center" style="min-height:100vh;">
        <div class="col-sm-12 col-md-6 col-lg-4">

            <!-- Dark mode toggle (top-right of the column) -->
            <div class="text-end mb-2">
                <button id="themeToggle" class="btn btn-outline-secondary btn-sm" onclick="toggleTheme()">
                    <i id="themeIcon" class="bi bi-moon-fill"></i>
                </button>
            </div>

            <!-- Brand header -->
            <div class="text-center mb-4">
                <div class="bg-dark rounded-circle d-inline-flex align-items-center justify-content-center mb-3"
                     style="width:60px;height:60px;">
                    <i class="bi bi-grid-3x3-gap-fill text-primary fs-4"></i>
                </div>
                <h4 class="fw-bold">Student System</h4>
                <p class="text-muted small">Sign in to access the dashboard</p>
            </div>

            <!-- ── Meme modal: auto-pops after 3+ failed attempts ── -->
            @if (Model.FailedAttempts >= 3)
            {
                <div class="modal fade" id="memeModal" tabindex="-1" aria-hidden="true">
                    <div class="modal-dialog modal-dialog-centered">
                        <div class="modal-content border-0 overflow-hidden shadow-lg">
                            <div class="position-relative">
                                <img src="~/images/meme.jpg" class="img-fluid w-100 d-block"
                                     alt="Wrong credentials meme"
                                     style="max-height:450px;object-fit:contain;" />
                                <span class="position-absolute top-0 end-0 badge bg-danger m-2">
                                    @Model.FailedAttempts attempt(s)
                                </span>
                            </div>
                            <div class="modal-footer bg-danger border-0 justify-content-center py-3">
                                <button type="button" class="btn btn-light fw-semibold px-4"
                                        data-bs-dismiss="modal">
                                    <i class="bi bi-check-circle-fill me-2 text-success"></i>Okay, I will
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            }

            <!-- Login card -->
            <div class="card shadow-sm border-0">
                <div class="card-body p-4">

                    <!-- Model-level error (wrong credentials) — only shown when there's a message -->
                    @{
                        var hasModelError = ViewData.ModelState.ContainsKey(string.Empty)
                                         && ViewData.ModelState[string.Empty]!.Errors.Count > 0;
                    }
                    @if (hasModelError)
                    {
                        <div class="alert alert-danger py-2 small d-flex align-items-center gap-2">
                            <i class="bi bi-exclamation-triangle-fill flex-shrink-0"></i>
                            @Html.ValidationSummary(true, null, new { @class = "mb-0" })
                        </div>
                    }

                    <form asp-action="Login" method="post" novalidate>
                        @Html.AntiForgeryToken()
                        <input type="hidden" asp-for="FailedAttempts" />
                        @if (ViewData["ReturnUrl"] is string ret)
                        {
                            <input type="hidden" name="returnUrl" value="@ret" />
                        }

                        <!-- Email -->
                        <div class="mb-3">
                            <label asp-for="Email" class="form-label fw-semibold">Email Address</label>
                            <input asp-for="Email" type="email" class="form-control"
                                   placeholder="admin@nexus.io" autofocus />
                            <span asp-validation-for="Email" class="text-danger small"></span>
                        </div>

                        <!-- Password -->
                        <div class="mb-3">
                            <label asp-for="Password" class="form-label fw-semibold">Password</label>
                            <input asp-for="Password" type="password" class="form-control"
                                   placeholder="••••••••" />
                            <span asp-validation-for="Password" class="text-danger small"></span>
                        </div>

                        <!-- Remember me -->
                        <div class="mb-3 form-check">
                            <input asp-for="RememberMe" type="checkbox" class="form-check-input" />
                            <label asp-for="RememberMe" class="form-check-label small">Keep me signed in</label>
                        </div>

                        <button type="submit" class="btn btn-primary w-100">
                            <i class="bi bi-box-arrow-in-right me-1"></i>Sign In
                        </button>
                    </form>

                </div>
            </div>

            <!-- Hint credentials -->
            <div class="card mt-3 border-0 bg-warning-subtle">
                <div class="card-body py-2 px-3 small">
                    <p class="mb-1">
                        <strong><i class="bi bi-shield-fill me-1 text-danger"></i>Admin:</strong>
                        admin@nexus.io / Admin@123
                    </p>
                    <p class="mb-0">
                        <strong><i class="bi bi-eye-fill me-1 text-secondary"></i>Viewer:</strong>
                        viewer@nexus.io / Viewer@123
                    </p>
                </div>
            </div>

        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<partial name="_ValidationScriptsPartial" />

<script>
    // Auto-open the meme modal when it exists (3+ failed attempts)
    document.addEventListener('DOMContentLoaded', function () {
        var el = document.getElementById('memeModal');
        if (el) { new bootstrap.Modal(el).show(); }
    });
</script>

<script>
    // Sync icon on page load
    (function () {
        var t = localStorage.getItem('theme') || 'light';
        document.getElementById('themeIcon').className = t === 'dark' ? 'bi bi-sun-fill' : 'bi bi-moon-fill';
    })();

    function toggleTheme() {
        var current = document.documentElement.getAttribute('data-bs-theme');
        var next = current === 'dark' ? 'light' : 'dark';
        document.documentElement.setAttribute('data-bs-theme', next);
        localStorage.setItem('theme', next);
        document.getElementById('themeIcon').className = next === 'dark' ? 'bi bi-sun-fill' : 'bi bi-moon-fill';
    }
</script>

</body>
</html>
