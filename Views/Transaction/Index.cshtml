@model List<ASPNetDashboard.Models.TransactionModel>
@{
    ViewData["Title"] = "Transactions";
    var role = User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value ?? "Viewer";
    var totalCredit = Model.Where(t => t.Type == "Credit").Sum(t => t.Amount);
    var totalDebit  = Model.Where(t => t.Type == "Debit").Sum(t => t.Amount);
    var net         = totalCredit - totalDebit;
}

<!-- ── Page heading ── -->
<div class="d-flex align-items-center justify-content-between mb-4">
    <div>
        <h4 class="fw-bold mb-0"><i class="bi bi-receipt text-success me-2"></i>Transactions</h4>
        <p class="text-muted small mb-0">@Model.Count record(s) shown</p>
    </div>
    @if (role == "Admin")
    {
        <a asp-action="Create" class="btn btn-success btn-sm">
            <i class="bi bi-plus-circle-fill me-1"></i>New Transaction
        </a>
    }
</div>

<!-- ── Summary cards ── -->
<div class="row g-3 mb-4">
    <div class="col-sm-12 col-md-4">
        <div class="card border-0 bg-success bg-opacity-10 shadow-sm">
            <div class="card-body d-flex align-items-center gap-3">
                <i class="bi bi-arrow-up-circle-fill text-success fs-3"></i>
                <div>
                    <div class="small text-muted">Total Credit</div>
                    <div class="fw-bold text-success">₱@String.Format("{0:N2}", totalCredit)</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-sm-12 col-md-4">
        <div class="card border-0 bg-danger bg-opacity-10 shadow-sm">
            <div class="card-body d-flex align-items-center gap-3">
                <i class="bi bi-arrow-down-circle-fill text-danger fs-3"></i>
                <div>
                    <div class="small text-muted">Total Debit</div>
                    <div class="fw-bold text-danger">₱@String.Format("{0:N2}", totalDebit)</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-sm-12 col-md-4">
        <div class="card border-0 bg-info bg-opacity-10 shadow-sm">
            <div class="card-body d-flex align-items-center gap-3">
                <i class="bi bi-wallet2 text-info fs-3"></i>
                <div>
                    <div class="small text-muted">Net Balance</div>
                    <div class="fw-bold @(net >= 0 ? "text-info" : "text-warning")">
                        ₱@String.Format("{0:N2}", net)
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- ── Filter form ── -->
<div class="card border-0 shadow-sm mb-4">
    <div class="card-body py-3">
        <form method="get" class="row g-2 align-items-end">
            <div class="col-sm-12 col-md-4">
                <label class="form-label small fw-semibold text-muted mb-1">Search</label>
                <input name="search" value="@ViewBag.Search" class="form-control form-control-sm"
                       placeholder="Description or reference…" />
            </div>
            <div class="col-sm-6 col-md-2">
                <label class="form-label small fw-semibold text-muted mb-1">Type</label>
                <select name="type" class="form-select form-select-sm">
                    <option value="">All</option>
                    <option value="Credit" selected="@(ViewBag.Type=="Credit"?"selected":null)">Credit</option>
                    <option value="Debit"  selected="@(ViewBag.Type=="Debit" ?"selected":null)">Debit</option>
                </select>
            </div>
            <div class="col-sm-6 col-md-3">
                <label class="form-label small fw-semibold text-muted mb-1">Category</label>
                <select name="category" class="form-select form-select-sm">
                    <option value="">All Categories</option>
                    @foreach (var cat in (ViewBag.Categories as List<string> ?? new()))
                    {
                        <option value="@cat" selected="@(ViewBag.Category==cat?"selected":null)">@cat</option>
                    }
                </select>
            </div>
            <div class="col-auto">
                <button type="submit" class="btn btn-primary btn-sm">
                    <i class="bi bi-search me-1"></i>Filter
                </button>
                @if (!string.IsNullOrEmpty(ViewBag.Search as string) || !string.IsNullOrEmpty(ViewBag.Type as string))
                {
                    <a asp-action="Index" class="btn btn-outline-secondary btn-sm ms-1">
                        <i class="bi bi-x-circle me-1"></i>Clear
                    </a>
                }
            </div>
        </form>
    </div>
</div>

<!-- ── Responsive table ── -->
<div class="card border-0 shadow-sm">
    <div class="card-body p-0">

        @if (!Model.Any())
        {
            <div class="text-center py-5 text-muted">
                <i class="bi bi-receipt-cutoff fs-1 d-block mb-2"></i>
                <p class="mb-0">No transactions found.</p>
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-striped table-hover table-bordered mb-0">
                    <thead class="table-active fw-semibold">
                        <tr>
                            <th>Reference</th>
                            <th>Description</th>
                            <th>Category</th>
                            <th>Type</th>
                            <th>Status</th>
                            <th>Amount</th>
                            <th>Date</th>
                            @if (role == "Admin") { <th class="text-end">Action</th> }
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var t in Model)
                        {
                            <tr>
                                <td class="text-muted small">@t.Reference</td>
                                <td class="fw-semibold">@t.Description</td>
                                <td class="small">@t.Category</td>
                                <td>
                                    <span class="badge @(t.Type=="Credit"?"bg-success":"bg-danger")">
                                        <i class="bi bi-arrow-@(t.Type=="Credit"?"up":"down") me-1"></i>@t.Type
                                    </span>
                                </td>
                                <td>
                                    <span class="badge @(t.Status=="Completed"?"bg-success":t.Status=="Pending"?"bg-warning text-dark":"bg-danger")">
                                        @t.Status
                                    </span>
                                </td>
                                <td class="fw-bold @(t.Type=="Credit"?"text-success":"text-danger")">
                                    @(t.Type=="Credit"?"+":"-")₱@String.Format("{0:N2}",t.Amount)
                                </td>
                                <td class="small text-muted">@t.Date.ToString("MMM dd, yyyy HH:mm")</td>
                                @if (role == "Admin")
                                {
                                    <td class="text-end">
                                        <form asp-action="Delete" asp-route-id="@t.Id" method="post" class="mb-0"
                                              onsubmit="return confirm('Delete this transaction?')">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn btn-danger btn-sm">
                                                <i class="bi bi-trash-fill"></i>
                                            </button>
                                        </form>
                                    </td>
                                }
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }

    </div>
</div>
