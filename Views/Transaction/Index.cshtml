@model List<ASPNetDashboard.Models.TransactionModel>
@{
    ViewData["Title"] = "Transactions";
    var role = User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value ?? "Viewer";
    var totalCredit = Model.Where(t => t.Type == "Credit").Sum(t => t.Amount);
    var totalDebit  = Model.Where(t => t.Type == "Debit").Sum(t => t.Amount);
}

<div class="d-flex align-items-center justify-content-between mb-3">
    <div>
        <div class="page-title">Transactions</div>
        <div class="page-sub">@Model.Count record(s) shown</div>
    </div>
    @if (role == "Admin")
    {
        <a asp-action="Create" class="btn btn-primary btn-sm">
            <i class="bi bi-plus-circle-fill me-1"></i>New Transaction
        </a>
    }
</div>

<!-- Summary strip -->
<div class="row g-2 mb-3">
    <div class="col-auto">
        <div style="background:rgba(16,185,129,.08);border:1px solid rgba(16,185,129,.18);border-radius:var(--r);padding:10px 16px;font-size:.8rem;color:#34d399;display:flex;align-items:center;gap:8px;">
            <i class="bi bi-arrow-up-circle-fill"></i>
            <span>Credits: <strong>&#8369;@String.Format("{0:N0}", totalCredit)</strong></span>
        </div>
    </div>
    <div class="col-auto">
        <div style="background:rgba(239,68,68,.07);border:1px solid rgba(239,68,68,.16);border-radius:var(--r);padding:10px 16px;font-size:.8rem;color:#f87171;display:flex;align-items:center;gap:8px;">
            <i class="bi bi-arrow-down-circle-fill"></i>
            <span>Debits: <strong>&#8369;@String.Format("{0:N0}", totalDebit)</strong></span>
        </div>
    </div>
    <div class="col-auto">
        @{ decimal net = totalCredit - totalDebit; }
        <div style="background:rgba(59,130,246,.07);border:1px solid rgba(59,130,246,.15);border-radius:var(--r);padding:10px 16px;font-size:.8rem;color:#60a5fa;display:flex;align-items:center;gap:8px;">
            <i class="bi bi-wallet2"></i>
            <span>Net: <strong>&#8369;@String.Format("{0:N0}", net)</strong></span>
        </div>
    </div>
</div>

<!-- Filter bar -->
<form method="get" class="filter-bar">
    <i class="bi bi-funnel-fill" style="color:var(--text-3);font-size:.85rem;"></i>
    <input name="search" value="@ViewBag.Search" class="form-control" style="width:220px;" placeholder="Search description or ref…" />
    <select name="type" class="form-select" style="width:150px;">
        <option value="">All Types</option>
        <option value="Credit" selected="@(ViewBag.Type == "Credit" ? "selected" : null)">Credit</option>
        <option value="Debit"  selected="@(ViewBag.Type == "Debit"  ? "selected" : null)">Debit</option>
    </select>
    <select name="category" class="form-select" style="width:160px;">
        <option value="">All Categories</option>
        @foreach (var cat in (ViewBag.Categories as List<string> ?? new()))
        {
            <option value="@cat" selected="@(ViewBag.Category == cat ? "selected" : null)">@cat</option>
        }
    </select>
    <button type="submit" class="btn btn-primary btn-sm"><i class="bi bi-search me-1"></i>Filter</button>
    @if (!string.IsNullOrEmpty(ViewBag.Search as string) || !string.IsNullOrEmpty(ViewBag.Type as string))
    {
        <a asp-action="Index" class="btn btn-outline-secondary btn-sm">
            <i class="bi bi-x-circle me-1"></i>Clear
        </a>
    }
</form>

<div class="card-dark">
    @if (!Model.Any())
    {
        <div class="empty-state">
            <div class="empty-icon"><i class="bi bi-receipt-cutoff"></i></div>
            <div class="empty-title">No transactions found</div>
            <div style="font-size:.8rem;">Try clearing your filters or add a new transaction.</div>
        </div>
    }
    else
    {
        <table class="table mb-0">
            <thead>
                <tr>
                    <th>Reference</th>
                    <th>Description</th>
                    <th>Type</th>
                    <th>Category</th>
                    <th>Status</th>
                    <th>Amount</th>
                    <th>Date</th>
                    @if (role == "Admin") { <th style="text-align:right;">Action</th> }
                </tr>
            </thead>
            <tbody>
                @foreach (var t in Model)
                {
                    <tr>
                        <td><span style="font-size:.72rem;color:var(--text-3);font-variant-numeric:tabular-nums;">@t.Reference</span></td>
                        <td><strong>@t.Description</strong></td>
                        <td>
                            <span class="badge-pill @(t.Type=="Credit" ? "bp-credit" : "bp-debit")">
                                <i class="bi bi-arrow-@(t.Type=="Credit"?"up":"down")"></i>@t.Type
                            </span>
                        </td>
                        <td><span style="color:var(--text-2);">@t.Category</span></td>
                        <td>
                            <span class="badge-pill @(t.Status=="Completed" ? "bp-complete" : t.Status=="Pending" ? "bp-pending" : "bp-failed")">
                                @t.Status
                            </span>
                        </td>
                        <td>
                            <strong style="color:@(t.Type=="Credit" ? "var(--green)" : "var(--red)");">
                                @(t.Type=="Credit"?"+":"-")&#8369;@String.Format("{0:N2}",t.Amount)
                            </strong>
                        </td>
                        <td style="color:var(--text-3);font-size:.78rem;white-space:nowrap;">@t.Date.ToString("MMM dd, yyyy HH:mm")</td>
                        @if (role == "Admin")
                        {
                            <td style="text-align:right;">
                                <form asp-action="Delete" asp-route-id="@t.Id" method="post" class="mb-0"
                                      onsubmit="return confirm('Remove this transaction?')">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-danger btn-sm">
                                        <i class="bi bi-trash-fill"></i>
                                    </button>
                                </form>
                            </td>
                        }
                    </tr>
                }
            </tbody>
        </table>
    }
</div>
