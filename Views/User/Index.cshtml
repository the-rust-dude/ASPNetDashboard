@model List<ASPNetDashboard.Models.UserModel>
@{
    ViewData["Title"] = "Table — Users";
    var role = User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value ?? "Viewer";
}

<!-- ── Page heading ── -->
<div class="d-flex align-items-center justify-content-between mb-4">
    <div>
        <h4 class="fw-bold mb-0"><i class="bi bi-table text-primary me-2"></i>User Records</h4>
        <p class="text-muted small mb-0">@Model.Count record(s) found in the database</p>
    </div>
    @if (role == "Admin")
    {
        <a asp-action="Create" class="btn btn-primary btn-sm">
            <i class="bi bi-person-plus-fill me-1"></i>Add User
        </a>
    }
</div>

<!-- ── Search & Filter form ── -->
<div class="card border-0 shadow-sm mb-4">
    <div class="card-body py-3">
        <form method="get" class="row g-2 align-items-end">
            <div class="col-sm-12 col-md-4 col-lg-4">
                <label class="form-label small fw-semibold text-muted mb-1">Search</label>
                <input name="search" value="@ViewBag.Search" class="form-control form-control-sm"
                       placeholder="Name, email, or department…" />
            </div>
            <div class="col-sm-6 col-md-3 col-lg-2">
                <label class="form-label small fw-semibold text-muted mb-1">Status</label>
                <select name="status" class="form-select form-select-sm">
                    <option value="">All</option>
                    <option value="Active"    selected="@(ViewBag.Status=="Active"    ?"selected":null)">Active</option>
                    <option value="Inactive"  selected="@(ViewBag.Status=="Inactive"  ?"selected":null)">Inactive</option>
                    <option value="Suspended" selected="@(ViewBag.Status=="Suspended" ?"selected":null)">Suspended</option>
                </select>
            </div>
            <div class="col-sm-6 col-md-3 col-lg-2">
                <label class="form-label small fw-semibold text-muted mb-1">Sort By</label>
                <select name="sortBy" class="form-select form-select-sm">
                    <option value="">Recent First</option>
                    <option value="name"   selected="@(ViewBag.SortBy=="name"   ?"selected":null)">Name A–Z</option>
                    <option value="age"    selected="@(ViewBag.SortBy=="age"    ?"selected":null)">Age</option>
                    <option value="status" selected="@(ViewBag.SortBy=="status" ?"selected":null)">Status</option>
                </select>
            </div>
            <div class="col-auto">
                <button type="submit" class="btn btn-primary btn-sm">
                    <i class="bi bi-search me-1"></i>Filter
                </button>
                @if (!string.IsNullOrEmpty(ViewBag.Search as string) || !string.IsNullOrEmpty(ViewBag.Status as string))
                {
                    <a asp-action="Index" class="btn btn-outline-secondary btn-sm ms-1">
                        <i class="bi bi-x-circle me-1"></i>Clear
                    </a>
                }
            </div>
        </form>
    </div>
</div>

<!-- ── Responsive table ── -->
<div class="card border-0 shadow-sm">
    <div class="card-body p-0">

        @if (!Model.Any())
        {
            <div class="text-center py-5 text-muted">
                <i class="bi bi-people fs-1 d-block mb-2"></i>
                <p class="mb-0">No users found. Try adjusting your filters.</p>
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-striped table-hover table-bordered mb-0">
                    <thead class="table-active fw-semibold">
                        <tr>
                            <th>ID</th>
                            <th>Name</th>
                            <th>Email</th>
                            <th>Course</th>
                            <th>Age</th>
                            <th>Status</th>
                            <th>Joined</th>
                            @if (role == "Admin") { <th class="text-end">Actions</th> }
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var u in Model)
                        {
                            <tr>
                                <td class="text-muted small">#@u.Id.ToString("D3")</td>
                                <td class="fw-semibold">@u.Name</td>
                                <td class="small text-muted">@u.Email</td>
                                <td class="small">@(string.IsNullOrEmpty(u.Department) ? "—" : u.Department)</td>
                                <td>@u.Age</td>
                                <td>
                                    <span class="badge @(u.Status=="Active"?"bg-success":u.Status=="Inactive"?"bg-secondary":"bg-danger")">
                                        @u.Status
                                    </span>
                                </td>
                                <td class="small text-muted">@u.CreatedAt.ToString("MMM dd, yyyy")</td>
                                @if (role == "Admin")
                                {
                                    <td class="text-end">
                                        <div class="d-flex gap-1 justify-content-end">
                                            <a asp-action="Edit" asp-route-id="@u.Id"
                                               class="btn btn-warning btn-sm">
                                                <i class="bi bi-pencil-fill"></i>
                                            </a>
                                            <form asp-action="Delete" asp-route-id="@u.Id" method="post" class="mb-0"
                                                  onsubmit="return confirm('Remove @u.Name?')">
                                                @Html.AntiForgeryToken()
                                                <button type="submit" class="btn btn-danger btn-sm">
                                                    <i class="bi bi-trash-fill"></i>
                                                </button>
                                            </form>
                                        </div>
                                    </td>
                                }
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }

    </div>
</div>
