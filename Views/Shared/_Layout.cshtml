<!DOCTYPE html>
<html lang="en" data-bs-theme="light">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — Student System</title>

    <!-- Bootstrap 5 CSS (CDN) — includes built-in dark mode via data-bs-theme -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <!-- Bootstrap Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />

    <!-- Apply saved theme BEFORE render so there's no light→dark flash -->
    <script>
        (function () {
            var t = localStorage.getItem('theme') || 'light';
            document.documentElement.setAttribute('data-bs-theme', t);
        })();
    </script>

    <style>
        /* ── Sidebar ── */
        .sidebar {
            min-height: calc(100vh - 56px);
            padding-top: 1rem;
        }
        .sidebar .nav-link {
            color: rgba(255,255,255,.72);
            border-radius: 6px;
            margin-bottom: 2px;
            font-size: .9rem;
        }
        .sidebar .nav-link:hover,
        .sidebar .nav-link.active {
            color: #fff;
            background-color: rgba(255,255,255,.13);
        }
        .sidebar .nav-link i { width: 20px; }

        /* ── Main content ── */
        .main-content {
            padding: 1.5rem;
            /* Uses Bootstrap's body background — switches automatically with data-bs-theme */
            background-color: var(--bs-body-bg);
            min-height: calc(100vh - 56px);
        }

        /* ── Sidebar stays dark in both modes (intentional — dark nav looks clean) ── */
        [data-bs-theme="dark"] .sidebar-wrapper {
            background-color: #1a1d20 !important;
        }

        /* ── Auto-fade flash alerts ── */
        .alert-flash { animation: fadeOut .4s ease 4s forwards; }
        @@keyframes fadeOut { to { opacity: 0; pointer-events: none; } }
    </style>
</head>
<body>

<!-- ── TOP NAVBAR ──────────────────────────────────────────────────── -->
<nav class="navbar navbar-dark bg-dark shadow-sm">
    <div class="container-fluid">
        <span class="navbar-brand fw-bold">
            <i class="bi bi-grid-3x3-gap-fill me-2 text-primary"></i>Student System
        </span>

        <div class="d-flex align-items-center gap-2">

            <!-- Dark / Light mode toggle -->
            <button id="themeToggle" class="btn btn-outline-light btn-sm" onclick="toggleTheme()"
                    title="Toggle dark/light mode">
                <i id="themeIcon" class="bi bi-moon-fill"></i>
            </button>

            @if (User.Identity?.IsAuthenticated == true)
            {
                <span class="text-white-50 small d-none d-md-inline">
                    <i class="bi bi-person-circle me-1"></i>@User.Identity.Name
                    <span class="badge bg-secondary ms-1">
                        @User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value
                    </span>
                </span>
                <form asp-controller="Account" asp-action="Logout" method="post" class="mb-0">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-outline-light btn-sm">
                        <i class="bi bi-box-arrow-right me-1"></i>Logout
                    </button>
                </form>
            }

        </div>
    </div>
</nav>

<!-- ── LAYOUT: SIDEBAR (col-md-3) + MAIN CONTENT (col-md-9) ─────── -->
<div class="container-fluid p-0">
    <div class="row g-0">

        @if (User.Identity?.IsAuthenticated == true)
        {
            <!-- SIDEBAR: always dark regardless of theme (dark nav is universally readable) -->
            <div class="col-sm-12 col-md-3 col-lg-2 bg-dark sidebar sidebar-wrapper">
                <nav class="nav flex-column px-2 pt-1">

                    <span class="text-uppercase text-white-50 px-2 mb-1 mt-1"
                          style="font-size:.7rem;letter-spacing:.08em;">Menu</span>

                    <!-- Home -->
                    <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString()=="Dashboard"?"active":"")"
                       asp-controller="Dashboard" asp-action="Index">
                        <i class="bi bi-house-door-fill me-2"></i>Home
                    </a>

                    <!-- Form (Add User) -->
                    <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString()=="User"&&
                                         ViewContext.RouteData.Values["action"]?.ToString()=="Create"?"active":"")"
                       asp-controller="User" asp-action="Create">
                        <i class="bi bi-person-plus-fill me-2"></i>Form
                    </a>

                    <!-- Table (User List) -->
                    <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString()=="User"&&
                                         ViewContext.RouteData.Values["action"]?.ToString()=="Index"?"active":"")"
                       asp-controller="User" asp-action="Index">
                        <i class="bi bi-table me-2"></i>Table
                    </a>

                    <hr class="border-secondary my-2"/>

                    <span class="text-uppercase text-white-50 px-2 mb-1"
                          style="font-size:.7rem;letter-spacing:.08em;">Finance</span>

                    <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString()=="Transaction"&&
                                         ViewContext.RouteData.Values["action"]?.ToString()=="Index"?"active":"")"
                       asp-controller="Transaction" asp-action="Index">
                        <i class="bi bi-receipt me-2"></i>Transactions
                    </a>

                    @if (User.IsInRole("Admin"))
                    {
                        <a class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString()=="Transaction"&&
                                             ViewContext.RouteData.Values["action"]?.ToString()=="Create"?"active":"")"
                           asp-controller="Transaction" asp-action="Create">
                            <i class="bi bi-plus-circle me-2"></i>New Transaction
                        </a>
                    }

                </nav>
            </div>
        }

        <!-- MAIN CONTENT -->
        <div class="@(User.Identity?.IsAuthenticated==true ? "col-sm-12 col-md-9 col-lg-10" : "col-12") main-content">

            <!-- Flash: Success -->
            @if (TempData["Success"] is string ok)
            {
                <div class="alert alert-success alert-dismissible alert-flash fade show mb-3" role="alert">
                    <i class="bi bi-check-circle-fill me-2"></i>@ok
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }

            <!-- Flash: Error -->
            @if (TempData["Error"] is string err)
            {
                <div class="alert alert-danger alert-dismissible alert-flash fade show mb-3" role="alert">
                    <i class="bi bi-exclamation-triangle-fill me-2"></i>@err
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }

            @RenderBody()

        </div>
    </div>
</div>

<!-- Bootstrap 5 JS bundle -->
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

<script>
    // ── Theme toggle ──────────────────────────────────────────────────
    // Bootstrap 5.3 supports data-bs-theme="dark" natively on the <html> element.
    // We persist the preference in localStorage so it survives navigation.

    // Sync icon immediately (theme was already applied in <head>)
    (function () {
        var t = localStorage.getItem('theme') || 'light';
        var icon = document.getElementById('themeIcon');
        if (icon) icon.className = t === 'dark' ? 'bi bi-sun-fill' : 'bi bi-moon-fill';
    })();

    function toggleTheme() {
        var current = document.documentElement.getAttribute('data-bs-theme');
        var next = current === 'dark' ? 'light' : 'dark';
        document.documentElement.setAttribute('data-bs-theme', next);
        localStorage.setItem('theme', next);
        document.getElementById('themeIcon').className =
            next === 'dark' ? 'bi bi-sun-fill' : 'bi bi-moon-fill';
    }
</script>

@await RenderSectionAsync("Scripts", required: false)

</body>
</html>
