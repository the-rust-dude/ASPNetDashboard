<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — Nexus</title>

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />

    <style>
        /* ══════════════════════════════════════════════════════════════
           NEXUS — OpsPulse-inspired Dark SaaS Design System
        ══════════════════════════════════════════════════════════════ */

        :root {
            --sw: 256px;

            /* Core palette */
            --bg:         #080c18;
            --bg-2:       #0d1226;
            --surface:    rgba(255,255,255,0.035);
            --surface-h:  rgba(255,255,255,0.06);
            --border:     rgba(255,255,255,0.07);
            --border-h:   rgba(255,255,255,0.13);

            /* Accent colours */
            --blue:    #3b82f6;
            --blue-d:  #1d4ed8;
            --violet:  #8b5cf6;
            --green:   #10b981;
            --amber:   #f59e0b;
            --red:     #ef4444;
            --cyan:    #06b6d4;

            /* Glow colours */
            --blue-g:   rgba(59,130,246,.15);
            --violet-g: rgba(139,92,246,.12);
            --green-g:  rgba(16,185,129,.12);
            --red-g:    rgba(239,68,68,.12);
            --amber-g:  rgba(245,158,11,.12);

            /* Text */
            --text:   #f1f5f9;
            --text-2: #94a3b8;
            --text-3: #475569;

            /* Radii */
            --r-sm:  8px;
            --r:     12px;
            --r-md:  16px;
            --r-lg:  20px;
            --r-xl:  24px;
            --pill:  999px;

            /* Shadows */
            --sh:    0 4px 24px rgba(0,0,0,.5);
            --sh-md: 0 8px 40px rgba(0,0,0,.55);
            --sh-lg: 0 20px 60px rgba(0,0,0,.6);
        }

        *, *::before, *::after { box-sizing: border-box; }

        body {
            font-family: 'Inter', sans-serif;
            background: var(--bg);
            background-image:
                radial-gradient(ellipse 65% 55% at 8% 2%,   rgba(59,130,246,.12)  0%, transparent 65%),
                radial-gradient(ellipse 50% 45% at 92% 95%,  rgba(139,92,246,.10)  0%, transparent 60%),
                radial-gradient(ellipse 45% 40% at 55% 55%,  rgba(16,185,129,.05)  0%, transparent 70%);
            background-attachment: fixed;
            color: var(--text);
            line-height: 1.6;
            min-height: 100vh;
        }

        /* Fine grid overlay */
        body::before {
            content: '';
            position: fixed; inset: 0;
            background-image:
                linear-gradient(rgba(255,255,255,.018) 1px, transparent 1px),
                linear-gradient(90deg, rgba(255,255,255,.018) 1px, transparent 1px);
            background-size: 48px 48px;
            pointer-events: none;
            z-index: 0;
        }

        /* ── SIDEBAR ─────────────────────────────────────────────────────── */
        #sidebar {
            width: var(--sw);
            min-height: 100vh;
            background: rgba(8,12,24,0.95);
            border-right: 1px solid var(--border);
            position: fixed; top: 0; left: 0;
            display: flex; flex-direction: column;
            z-index: 1000;
            backdrop-filter: blur(20px);
            overflow: hidden;
        }
        #sidebar::before {
            content: '';
            position: absolute; width: 260px; height: 260px;
            background: radial-gradient(circle, rgba(59,130,246,.14) 0%, transparent 70%);
            top: -80px; left: -60px; pointer-events: none;
        }
        #sidebar::after {
            content: '';
            position: absolute; width: 180px; height: 180px;
            background: radial-gradient(circle, rgba(139,92,246,.1) 0%, transparent 70%);
            bottom: 120px; right: -50px; pointer-events: none;
        }

        .sb-brand {
            display: flex; align-items: center; gap: 11px;
            padding: 22px 20px 16px;
            position: relative; z-index: 1;
            border-bottom: 1px solid var(--border);
        }
        .sb-logo {
            width: 36px; height: 36px;
            background: linear-gradient(135deg, #3b82f6, #8b5cf6);
            border-radius: var(--r-sm);
            display: flex; align-items: center; justify-content: center;
            color: #fff; font-size: 1rem; flex-shrink: 0;
            box-shadow: 0 0 20px rgba(59,130,246,.4);
        }
        .sb-title { font-size: 1.05rem; font-weight: 800; color: #fff; letter-spacing: -0.02em; }
        .sb-title span {
            background: linear-gradient(135deg, #3b82f6, #8b5cf6);
            -webkit-background-clip: text; -webkit-text-fill-color: transparent;
            background-clip: text;
        }
        .sb-version {
            font-size: 0.6rem; color: var(--text-3); font-weight: 500;
            letter-spacing: .05em; text-transform: uppercase;
        }

        .sb-section { position: relative; z-index: 1; }
        .sb-label {
            font-size: 0.6rem; font-weight: 700;
            letter-spacing: .14em; text-transform: uppercase;
            color: var(--text-3);
            padding: 16px 20px 5px;
        }
        .sb-nav .nav-link {
            display: flex; align-items: center; gap: 10px;
            color: var(--text-3);
            padding: 8px 12px; margin: 2px 10px;
            border-radius: var(--r);
            font-size: 0.84rem; font-weight: 500;
            transition: all 0.18s ease;
            position: relative;
        }
        .sb-nav .nav-link .nav-icon {
            width: 30px; height: 30px;
            background: rgba(255,255,255,.04);
            border: 1px solid var(--border);
            border-radius: var(--r-sm);
            display: flex; align-items: center; justify-content: center;
            font-size: 0.85rem; flex-shrink: 0;
            transition: all .18s;
        }
        .sb-nav .nav-link:hover {
            color: var(--text);
            background: var(--surface-h);
        }
        .sb-nav .nav-link:hover .nav-icon {
            background: rgba(59,130,246,.1);
            border-color: rgba(59,130,246,.25);
            color: var(--blue);
        }
        .sb-nav .nav-link.active {
            color: var(--text);
            background: rgba(59,130,246,.1);
            border: 1px solid rgba(59,130,246,.2);
        }
        .sb-nav .nav-link.active .nav-icon {
            background: rgba(59,130,246,.18);
            border-color: rgba(59,130,246,.35);
            color: #60a5fa;
        }
        .sb-nav .nav-link.active::before {
            content: '';
            position: absolute; left: -10px; top: 50%; transform: translateY(-50%);
            width: 3px; height: 60%; background: var(--blue);
            border-radius: 0 var(--pill) var(--pill) 0;
        }

        /* Status dot */
        .nav-dot {
            width: 6px; height: 6px; border-radius: 50%;
            margin-left: auto; flex-shrink: 0;
        }
        .dot-blue   { background: var(--blue); box-shadow: 0 0 6px var(--blue); }
        .dot-green  { background: var(--green); box-shadow: 0 0 6px var(--green); }
        .dot-amber  { background: var(--amber); box-shadow: 0 0 6px var(--amber); }

        .sb-foot {
            margin-top: auto;
            border-top: 1px solid var(--border);
            padding: 14px;
            position: relative; z-index: 1;
        }
        .sb-user-card {
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: var(--r-md);
            padding: 11px 13px;
            display: flex; align-items: center; gap: 10px;
        }
        .sb-avatar {
            width: 32px; height: 32px; border-radius: 50%;
            background: linear-gradient(135deg, #3b82f6, #8b5cf6);
            display: flex; align-items: center; justify-content: center;
            font-size: 0.78rem; font-weight: 700; color: #fff; flex-shrink: 0;
            box-shadow: 0 0 12px rgba(59,130,246,.3);
        }
        .sb-user-name { font-size: 0.82rem; font-weight: 600; color: var(--text); line-height: 1.2; }
        .sb-user-role { font-size: 0.66rem; color: var(--text-3); }
        .sb-role-badge {
            margin-left: auto; flex-shrink: 0;
            font-size: 0.6rem; font-weight: 700;
            padding: 3px 8px; border-radius: var(--pill);
            letter-spacing: .04em; text-transform: uppercase;
        }
        .role-admin  { background: rgba(59,130,246,.15); color: #93c5fd; border: 1px solid rgba(59,130,246,.25); }
        .role-viewer { background: rgba(139,92,246,.12); color: #c4b5fd; border: 1px solid rgba(139,92,246,.2); }

        .btn-logout {
            display: flex; align-items: center; gap: 7px;
            width: 100%; margin-top: 8px;
            background: rgba(239,68,68,.05);
            border: 1px solid rgba(239,68,68,.1);
            border-radius: var(--r);
            padding: 7px 12px;
            font-size: 0.78rem; font-weight: 500;
            color: rgba(239,68,68,.7);
            cursor: pointer; transition: all .2s;
            font-family: inherit;
        }
        .btn-logout:hover {
            background: rgba(239,68,68,.1);
            border-color: rgba(239,68,68,.25);
            color: #fca5a5;
        }

        /* ── MAIN ─────────────────────────────────────────────────────────── */
        #main-content {
            margin-left: var(--sw);
            min-height: 100vh;
            display: flex; flex-direction: column;
            position: relative; z-index: 1;
        }

        /* ── TOPBAR ───────────────────────────────────────────────────────── */
        #topbar {
            background: rgba(8,12,24,0.7);
            backdrop-filter: blur(20px);
            border-bottom: 1px solid var(--border);
            padding: 0 28px;
            height: 60px;
            display: flex; align-items: center; justify-content: space-between;
            position: sticky; top: 0; z-index: 100;
        }
        .tb-left { display: flex; align-items: center; gap: 16px; }
        .tb-breadcrumb {
            display: flex; align-items: center; gap: 6px;
            font-size: 0.78rem; color: var(--text-3);
        }
        .tb-breadcrumb span { color: var(--text-2); font-weight: 500; }
        .tb-title {
            font-size: 0.95rem; font-weight: 700; color: var(--text);
            display: flex; align-items: center; gap: 9px;
        }
        .tb-icon {
            width: 28px; height: 28px;
            background: var(--blue-g);
            border: 1px solid rgba(59,130,246,.22);
            border-radius: var(--r-sm);
            display: flex; align-items: center; justify-content: center;
            font-size: 0.78rem; color: #60a5fa;
        }

        .tb-right { display: flex; align-items: center; gap: 10px; }

        .tb-status {
            display: flex; align-items: center; gap: 6px;
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: var(--pill);
            padding: 5px 12px;
            font-size: 0.73rem; color: var(--text-2);
        }
        .status-dot {
            width: 6px; height: 6px; border-radius: 50%;
            background: var(--green);
            box-shadow: 0 0 6px var(--green);
            animation: pulse 2s infinite;
        }
        @@keyframes pulse {
            0%, 100% { opacity: 1; }
            50%       { opacity: .5; }
        }

        .tb-time {
            font-size: 0.73rem; color: var(--text-3);
            font-variant-numeric: tabular-nums;
        }

        .tb-btn {
            width: 32px; height: 32px;
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: var(--r-sm);
            display: flex; align-items: center; justify-content: center;
            color: var(--text-2); cursor: pointer;
            font-size: 0.88rem; transition: all .18s;
        }
        .tb-btn:hover { background: var(--surface-h); border-color: var(--border-h); color: var(--text); }

        /* ── PAGE BODY ────────────────────────────────────────────────────── */
        .page-body { padding: 24px 28px; flex: 1; }

        .page-header { margin-bottom: 22px; }
        .page-title {
            font-size: 1.25rem; font-weight: 800;
            color: var(--text); letter-spacing: -0.025em;
            line-height: 1.2;
        }
        .page-sub { font-size: 0.82rem; color: var(--text-2); margin-top: 3px; }

        /* ── CARDS / GLASS ────────────────────────────────────────────────── */
        .card-dark {
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: var(--r-lg);
            overflow: hidden;
        }
        .card-dark-pad { padding: 20px 22px; }

        .card-head {
            display: flex; align-items: center; justify-content: space-between;
            padding: 16px 20px;
            border-bottom: 1px solid var(--border);
        }
        .card-title-row {
            display: flex; align-items: center; gap: 8px;
            font-size: 0.88rem; font-weight: 600; color: var(--text);
        }
        .card-dot {
            width: 7px; height: 7px; border-radius: 50%;
            background: var(--blue);
            box-shadow: 0 0 8px var(--blue);
        }
        .card-dot.green  { background: var(--green);  box-shadow: 0 0 8px var(--green); }
        .card-dot.violet { background: var(--violet); box-shadow: 0 0 8px var(--violet); }
        .card-dot.amber  { background: var(--amber);  box-shadow: 0 0 8px var(--amber); }
        .card-dot.red    { background: var(--red);    box-shadow: 0 0 8px var(--red); }

        /* ── STAT CARDS ───────────────────────────────────────────────────── */
        .stat-card {
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: var(--r-lg);
            padding: 20px;
            position: relative; overflow: hidden;
            transition: transform .2s ease, border-color .2s ease, box-shadow .2s ease;
        }
        .stat-card:hover {
            transform: translateY(-2px);
            border-color: var(--border-h);
            box-shadow: 0 8px 32px rgba(0,0,0,.4);
        }
        .stat-card::after {
            content: '';
            position: absolute; top: 0; right: 0;
            width: 120px; height: 120px;
            border-radius: 50%;
            opacity: 0.5;
            transform: translate(30%, -30%);
            pointer-events: none;
        }
        .sc-blue::after   { background: radial-gradient(circle, rgba(59,130,246,.2), transparent 70%); }
        .sc-green::after  { background: radial-gradient(circle, rgba(16,185,129,.2), transparent 70%); }
        .sc-red::after    { background: radial-gradient(circle, rgba(239,68,68,.2),  transparent 70%); }
        .sc-violet::after { background: radial-gradient(circle, rgba(139,92,246,.2), transparent 70%); }
        .sc-amber::after  { background: radial-gradient(circle, rgba(245,158,11,.2), transparent 70%); }

        .stat-icon {
            width: 38px; height: 38px;
            border-radius: var(--r-sm);
            display: flex; align-items: center; justify-content: center;
            font-size: 1rem; margin-bottom: 14px;
        }
        .si-blue   { background: rgba(59,130,246,.14);  color: #60a5fa;  border: 1px solid rgba(59,130,246,.25); }
        .si-green  { background: rgba(16,185,129,.12);  color: #34d399;  border: 1px solid rgba(16,185,129,.22); }
        .si-red    { background: rgba(239,68,68,.1);    color: #f87171;  border: 1px solid rgba(239,68,68,.2); }
        .si-violet { background: rgba(139,92,246,.12);  color: #a78bfa;  border: 1px solid rgba(139,92,246,.22); }
        .si-amber  { background: rgba(245,158,11,.1);   color: #fbbf24;  border: 1px solid rgba(245,158,11,.2); }

        .stat-label {
            font-size: 0.7rem; font-weight: 600;
            text-transform: uppercase; letter-spacing: .09em;
            color: var(--text-3); margin-bottom: 5px;
        }
        .stat-value {
            font-size: 1.65rem; font-weight: 800;
            color: var(--text); letter-spacing: -0.035em; line-height: 1.1;
        }
        .stat-sub {
            font-size: 0.72rem; color: var(--text-3); margin-top: 5px;
            display: flex; align-items: center; gap: 4px;
        }
        .stat-trend {
            font-size: 0.7rem; font-weight: 600;
            display: inline-flex; align-items: center; gap: 2px;
            padding: 2px 7px; border-radius: var(--pill);
        }
        .trend-up   { background: rgba(16,185,129,.12); color: #34d399; }
        .trend-down { background: rgba(239,68,68,.1);   color: #f87171; }

        /* ── TABLE ────────────────────────────────────────────────────────── */
        .table {
            margin: 0;
            --bs-table-bg: transparent;
            --bs-table-color: var(--text);
            --bs-table-border-color: var(--border);
        }
        .table thead th {
            background: rgba(255,255,255,.02);
            color: var(--text-3);
            font-size: 0.66rem; font-weight: 700;
            text-transform: uppercase; letter-spacing: .1em;
            border: none; padding: 11px 18px;
            white-space: nowrap;
        }
        .table tbody td {
            padding: 13px 18px; vertical-align: middle;
            color: var(--text-2); border-color: var(--border);
            font-size: 0.84rem;
        }
        .table tbody td strong { color: var(--text); }
        .table tbody tr:last-child td { border-bottom: none; }
        .table tbody tr { transition: background .12s; }
        .table tbody tr:hover td { background: var(--surface-h); color: var(--text); }

        /* ── USER AVATAR ──────────────────────────────────────────────────── */
        .u-ava {
            width: 32px; height: 32px; border-radius: 50%;
            background: linear-gradient(135deg, #3b82f6, #8b5cf6);
            color: #fff; display: flex; align-items: center; justify-content: center;
            font-size: 0.75rem; font-weight: 700; flex-shrink: 0;
        }
        .u-name { font-size: 0.85rem; font-weight: 600; color: var(--text); line-height: 1.2; }
        .u-email { font-size: 0.73rem; color: var(--text-3); }

        /* ── BADGES ───────────────────────────────────────────────────────── */
        .badge-pill {
            display: inline-flex; align-items: center; gap: 4px;
            padding: 3px 10px; border-radius: var(--pill);
            font-size: 0.68rem; font-weight: 700;
            letter-spacing: .03em;
        }
        .bp-credit   { background: rgba(16,185,129,.1);  color: #34d399; border: 1px solid rgba(16,185,129,.2); }
        .bp-debit    { background: rgba(239,68,68,.08);  color: #f87171; border: 1px solid rgba(239,68,68,.16); }
        .bp-active   { background: rgba(16,185,129,.1);  color: #34d399; border: 1px solid rgba(16,185,129,.2); }
        .bp-inactive { background: rgba(245,158,11,.08); color: #fbbf24; border: 1px solid rgba(245,158,11,.18); }
        .bp-suspend  { background: rgba(239,68,68,.08);  color: #f87171; border: 1px solid rgba(239,68,68,.16); }
        .bp-complete { background: rgba(16,185,129,.1);  color: #34d399; border: 1px solid rgba(16,185,129,.2); }
        .bp-pending  { background: rgba(245,158,11,.08); color: #fbbf24; border: 1px solid rgba(245,158,11,.18); }
        .bp-failed   { background: rgba(239,68,68,.08);  color: #f87171; border: 1px solid rgba(239,68,68,.16); }
        .bp-admin    { background: rgba(59,130,246,.12); color: #93c5fd; border: 1px solid rgba(59,130,246,.22); }
        .bp-viewer   { background: rgba(139,92,246,.1);  color: #c4b5fd; border: 1px solid rgba(139,92,246,.2); }

        /* ── FORMS ────────────────────────────────────────────────────────── */
        .form-wrap {
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: var(--r-xl);
            padding: 30px 34px;
        }
        .form-header { margin-bottom: 26px; padding-bottom: 20px; border-bottom: 1px solid var(--border); }
        .form-h-icon {
            width: 44px; height: 44px;
            background: linear-gradient(135deg, #3b82f6, #8b5cf6);
            border-radius: var(--r);
            display: flex; align-items: center; justify-content: center;
            color: #fff; font-size: 1.1rem;
            box-shadow: 0 4px 16px rgba(59,130,246,.3);
        }
        .form-h-icon.amber { background: linear-gradient(135deg, #f59e0b, #fbbf24); box-shadow: 0 4px 16px rgba(245,158,11,.3); }
        .form-h-title { font-size: 1.05rem; font-weight: 700; color: var(--text); }
        .form-h-sub   { font-size: 0.78rem; color: var(--text-3); }

        .form-label {
            font-size: 0.71rem; font-weight: 700;
            text-transform: uppercase; letter-spacing: .07em;
            color: var(--text-3); margin-bottom: 7px;
        }
        .form-control, .form-select {
            background: rgba(255,255,255,.04);
            border: 1.5px solid var(--border);
            border-radius: var(--r);
            padding: 11px 14px;
            font-family: inherit; font-size: 0.88rem;
            color: var(--text);
            transition: all .18s;
        }
        .form-control::placeholder { color: var(--text-3); }
        .form-control:focus, .form-select:focus {
            background: rgba(59,130,246,.05);
            border-color: rgba(59,130,246,.5);
            box-shadow: 0 0 0 3px rgba(59,130,246,.1);
            outline: none; color: var(--text);
        }
        .form-select option { background: #0d1226; }
        .form-control.is-invalid { border-color: var(--red); box-shadow: 0 0 0 3px rgba(239,68,68,.08); }
        .invalid-feedback { font-size: 0.76rem; color: #f87171; margin-top: 5px; }
        .input-group-text {
            background: rgba(255,255,255,.03);
            border: 1.5px solid var(--border); border-right: none;
            color: var(--text-3);
        }

        /* ── BUTTONS ──────────────────────────────────────────────────────── */
        .btn { font-family: inherit; font-weight: 600; border-radius: var(--pill); transition: all .18s; }
        .btn-primary {
            background: linear-gradient(135deg, #3b82f6, #6d28d9);
            border: none; color: #fff;
            padding: 9px 22px;
            box-shadow: 0 4px 16px rgba(59,130,246,.3);
        }
        .btn-primary:hover { filter: brightness(1.1); transform: translateY(-1px); color: #fff; border: none; }
        .btn-outline-primary {
            background: transparent;
            border: 1.5px solid rgba(59,130,246,.3);
            color: #60a5fa; padding: 6px 16px; font-size: 0.8rem;
        }
        .btn-outline-primary:hover { background: var(--blue-g); border-color: rgba(59,130,246,.5); color: #93c5fd; }
        .btn-outline-secondary {
            background: var(--surface);
            border: 1.5px solid var(--border);
            color: var(--text-2); padding: 9px 20px;
        }
        .btn-outline-secondary:hover { background: var(--surface-h); border-color: var(--border-h); color: var(--text); }
        .btn-warning {
            background: linear-gradient(135deg,#f59e0b,#fbbf24); border: none; color: #0f172a;
            padding: 6px 16px; font-size: 0.8rem;
        }
        .btn-warning:hover { filter: brightness(1.08); transform: translateY(-1px); color: #0f172a; }
        .btn-danger {
            background: linear-gradient(135deg,#ef4444,#f87171); border: none; color: #fff;
            padding: 6px 16px; font-size: 0.8rem;
        }
        .btn-danger:hover { filter: brightness(1.08); transform: translateY(-1px); color: #fff; }
        .btn-sm { padding: 5px 13px; font-size: 0.76rem; }

        /* ── FILTER BAR ───────────────────────────────────────────────────── */
        .filter-bar {
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: var(--r-md);
            padding: 14px 18px;
            margin-bottom: 16px;
            display: flex; align-items: center; gap: 10px; flex-wrap: wrap;
        }
        .filter-bar .form-control, .filter-bar .form-select {
            background: rgba(255,255,255,.03);
            padding: 8px 12px; font-size: 0.82rem;
        }

        /* ── ALERTS ───────────────────────────────────────────────────────── */
        .alert {
            border-radius: var(--r); border: none;
            font-size: 0.84rem; padding: 12px 16px;
            font-weight: 500;
            display: flex; align-items: center; gap: 10px;
        }
        .alert-success { background: rgba(16,185,129,.08); color: #34d399; border: 1px solid rgba(16,185,129,.18); }
        .alert-info    { background: rgba(59,130,246,.07); color: #60a5fa; border: 1px solid rgba(59,130,246,.16); }
        .alert-danger  { background: rgba(239,68,68,.08);  color: #f87171; border: 1px solid rgba(239,68,68,.16); }
        .btn-close { filter: invert(1) opacity(.4); }
        .btn-close:hover { filter: invert(1) opacity(.7); }

        /* ── EMPTY STATE ──────────────────────────────────────────────────── */
        .empty-state {
            text-align: center; padding: 52px 24px;
            color: var(--text-3);
        }
        .empty-icon {
            width: 64px; height: 64px;
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: 50%;
            display: flex; align-items: center; justify-content: center;
            font-size: 1.6rem; color: var(--text-3);
            margin: 0 auto 14px;
        }
        .empty-title { font-size: 0.95rem; font-weight: 600; color: var(--text-2); margin-bottom: 4px; }

        /* ── FOOTER ───────────────────────────────────────────────────────── */
        footer {
            padding: 16px 28px;
            border-top: 1px solid var(--border);
            display: flex; align-items: center; justify-content: space-between;
            font-size: 0.72rem; color: var(--text-3);
        }
        footer a { color: var(--text-3); text-decoration: none; }
        footer a:hover { color: var(--text-2); }

        /* ── RESPONSIVE ───────────────────────────────────────────────────── */
        @@media (max-width: 768px) {
            :root { --sw: 60px; }
            .sb-title, .sb-version, .sb-label,
            .sb-nav .nav-link span:not(.nav-icon),
            .sb-user-name, .sb-user-role, .sb-role-badge,
            .btn-logout span { display: none; }
            .sb-brand { justify-content: center; padding: 16px 10px; }
            .sb-nav .nav-link { justify-content: center; margin: 2px 6px; padding: 9px; }
            .sb-nav .nav-link .nav-icon { width: 34px; height: 34px; }
            .sb-nav .nav-link.active::before { display: none; }
            .sb-foot { padding: 8px 6px; }
            .sb-user-card { justify-content: center; padding: 9px; }
            .page-body { padding: 16px; }
        }
    </style>
</head>
<body>

@{
    var userEmail    = User.FindFirst(System.Security.Claims.ClaimTypes.Email)?.Value ?? "";
    var userName     = User.FindFirst(System.Security.Claims.ClaimTypes.Name)?.Value ?? "User";
    var userRole     = User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value ?? "Viewer";
    var ctrl         = ViewContext.RouteData.Values["controller"]?.ToString() ?? "";
    var act          = ViewContext.RouteData.Values["action"]?.ToString() ?? "";
    var initials     = string.Join("", userName.Split(' ').Take(2).Select(p => p[0]));
    string TbIcon()  => ctrl switch {
        "Dashboard"   => "grid-1x2-fill",
        "User"        => "people-fill",
        "Transaction" => "receipt-cutoff",
        _             => "circle-fill"
    };
    bool IsActive(string c, string? a = null) =>
        ctrl == c && (a == null || act == a);
}

<!-- ░░░ SIDEBAR ░░░ -->
<div id="sidebar">
    <div class="sb-brand">
        <div class="sb-logo"><i class="bi bi-layers-fill"></i></div>
        <div>
            <div class="sb-title">Ne<span>xus</span></div>
            <div class="sb-version">Ops Platform v2.0</div>
        </div>
    </div>

    <nav class="sb-nav sb-section mt-2">
        <div class="sb-label">Overview</div>
        <a class="nav-link @(IsActive("Dashboard") ? "active" : "")"
           asp-controller="Dashboard" asp-action="Index">
            <span class="nav-icon"><i class="bi bi-grid-1x2-fill"></i></span>
            <span>Dashboard</span>
            <span class="nav-dot dot-blue"></span>
        </a>

        <div class="sb-label">People</div>
        <a class="nav-link @(IsActive("User","Index") ? "active" : "")"
           asp-controller="User" asp-action="Index">
            <span class="nav-icon"><i class="bi bi-people-fill"></i></span>
            <span>Users</span>
        </a>
        @if (userRole == "Admin")
        {
            <a class="nav-link @(IsActive("User","Create") ? "active" : "")"
               asp-controller="User" asp-action="Create">
                <span class="nav-icon"><i class="bi bi-person-plus-fill"></i></span>
                <span>Add User</span>
            </a>
        }

        <div class="sb-label">Finance</div>
        <a class="nav-link @(IsActive("Transaction","Index") ? "active" : "")"
           asp-controller="Transaction" asp-action="Index">
            <span class="nav-icon"><i class="bi bi-receipt-cutoff"></i></span>
            <span>Transactions</span>
            <span class="nav-dot dot-green"></span>
        </a>
        @if (userRole == "Admin")
        {
            <a class="nav-link @(IsActive("Transaction","Create") ? "active" : "")"
               asp-controller="Transaction" asp-action="Create">
                <span class="nav-icon"><i class="bi bi-plus-circle-fill"></i></span>
                <span>New Transaction</span>
            </a>
        }
    </nav>

    <div class="sb-foot">
        <div class="sb-user-card">
            <div class="sb-avatar">@initials</div>
            <div style="flex:1;min-width:0;">
                <div class="sb-user-name text-truncate">@userName</div>
                <div class="sb-user-role text-truncate">@userEmail</div>
            </div>
            <span class="sb-role-badge @(userRole == "Admin" ? "role-admin" : "role-viewer")">
                @userRole
            </span>
        </div>
        <form asp-controller="Account" asp-action="Logout" method="post" class="mb-0 mt-1">
            @Html.AntiForgeryToken()
            <button type="submit" class="btn-logout">
                <i class="bi bi-box-arrow-left"></i>
                <span>Sign Out</span>
            </button>
        </form>
    </div>
</div>

<!-- ░░░ MAIN ░░░ -->
<div id="main-content">
    <!-- Topbar -->
    <div id="topbar">
        <div class="tb-left">
            <div class="tb-title">
                <div class="tb-icon"><i class="bi bi-@TbIcon()"></i></div>
                @ViewData["Title"]
            </div>
        </div>
        <div class="tb-right">
            <div class="tb-status">
                <div class="status-dot"></div>
                All systems operational
            </div>
            <div class="tb-time" id="tb-clock"></div>
            <div class="tb-btn" title="@userName — @userRole">
                <i class="bi bi-person-fill"></i>
            </div>
        </div>
    </div>

    <!-- Flash Messages -->
    <div style="padding: 0 28px;">
        @if (TempData["Success"] is string success)
        {
            <div class="alert alert-success alert-dismissible fade show mt-3" role="alert">
                <i class="bi bi-check-circle-fill"></i>
                <span>@success</span>
                <button type="button" class="btn-close ms-auto" data-bs-dismiss="alert"></button>
            </div>
        }
        @if (TempData["Info"] is string info)
        {
            <div class="alert alert-info alert-dismissible fade show mt-3" role="alert">
                <i class="bi bi-info-circle-fill"></i>
                <span>@info</span>
                <button type="button" class="btn-close ms-auto" data-bs-dismiss="alert"></button>
            </div>
        }
        @if (TempData["Error"] is string error)
        {
            <div class="alert alert-danger alert-dismissible fade show mt-3" role="alert">
                <i class="bi bi-exclamation-triangle-fill"></i>
                <span>@error</span>
                <button type="button" class="btn-close ms-auto" data-bs-dismiss="alert"></button>
            </div>
        }
    </div>

    <main class="page-body">@RenderBody()</main>

    <footer>
        <span>&copy; @DateTime.Now.Year Nexus Operations Platform</span>
        <span>SQLite &bull; ASP.NET Core MVC</span>
    </footer>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.7.1/jquery.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validate/1.19.5/jquery.validate.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validation-unobtrusive/4.0.0/jquery.validate.unobtrusive.min.js"></script>

<script>
    // Live clock
    const clockEl = document.getElementById('tb-clock');
    function updateClock() {
        const now = new Date();
        clockEl.textContent = now.toLocaleTimeString('en-US', { hour12: false, hour:'2-digit', minute:'2-digit', second:'2-digit' });
    }
    updateClock();
    setInterval(updateClock, 1000);
</script>

@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
