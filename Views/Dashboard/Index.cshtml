@{
    ViewData["Title"] = "Dashboard";
    var role = User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value ?? "Viewer";
    var name = User.FindFirst(System.Security.Claims.ClaimTypes.Name)?.Value ?? "User";
    decimal net = ViewBag.NetBalance;
}

<!-- ── Page heading ── -->
<div class="d-flex align-items-center justify-content-between mb-4">
    <div>
        <h4 class="fw-bold mb-0">Welcome, @name.Split(' ')[0]!</h4>
        <p class="text-muted small mb-0">
            @if (role == "Admin")
            {
                <span><i class="bi bi-shield-fill text-primary me-1"></i>Admin — full access</span>
            }
            else
            {
                <span><i class="bi bi-eye-fill text-secondary me-1"></i>Viewer — read-only</span>
            }
        </p>
    </div>
    @if (role == "Admin")
    {
        <div class="d-flex gap-2">
            <a asp-controller="User" asp-action="Create" class="btn btn-primary btn-sm">
                <i class="bi bi-person-plus-fill me-1"></i>Add User
            </a>
            <a asp-controller="Transaction" asp-action="Create" class="btn btn-success btn-sm">
                <i class="bi bi-plus-circle me-1"></i>New Transaction
            </a>
        </div>
    }
</div>

<!-- ── Stat cards — responsive grid ── -->
<div class="row g-3 mb-4">

    <!-- Total Users -->
    <div class="col-sm-12 col-md-6 col-lg-3">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="bg-primary bg-opacity-10 rounded-3 p-3">
                    <i class="bi bi-people-fill text-primary fs-4"></i>
                </div>
                <div>
                    <div class="text-muted small">Total Users</div>
                    <div class="fs-4 fw-bold">@ViewBag.UserCount</div>
                    <div class="small text-success">@ViewBag.ActiveUsers active</div>
                </div>
            </div>
        </div>
    </div>

    <!-- Total Credit -->
    <div class="col-sm-12 col-md-6 col-lg-3">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="bg-success bg-opacity-10 rounded-3 p-3">
                    <i class="bi bi-arrow-up-circle-fill text-success fs-4"></i>
                </div>
                <div>
                    <div class="text-muted small">Total Credit</div>
                    <div class="fs-5 fw-bold">₱@String.Format("{0:N0}", ViewBag.TotalCredit)</div>
                    <div class="small text-muted">Incoming</div>
                </div>
            </div>
        </div>
    </div>

    <!-- Total Debit -->
    <div class="col-sm-12 col-md-6 col-lg-3">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="bg-danger bg-opacity-10 rounded-3 p-3">
                    <i class="bi bi-arrow-down-circle-fill text-danger fs-4"></i>
                </div>
                <div>
                    <div class="text-muted small">Total Debit</div>
                    <div class="fs-5 fw-bold">₱@String.Format("{0:N0}", ViewBag.TotalDebit)</div>
                    <div class="small text-muted">Outgoing</div>
                </div>
            </div>
        </div>
    </div>

    <!-- Net Balance -->
    <div class="col-sm-12 col-md-6 col-lg-3">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="@(net >= 0 ? "bg-info" : "bg-warning") bg-opacity-10 rounded-3 p-3">
                    <i class="bi bi-wallet2 @(net >= 0 ? "text-info" : "text-warning") fs-4"></i>
                </div>
                <div>
                    <div class="text-muted small">Net Balance</div>
                    <div class="fs-5 fw-bold @(net >= 0 ? "text-info" : "text-warning")">
                        ₱@String.Format("{0:N0}", net)
                    </div>
                    <div class="small text-muted">Credit − Debit</div>
                </div>
            </div>
        </div>
    </div>

</div>

<!-- ── Recent data: two columns ── -->
<div class="row g-3">

    <!-- Recent Users -->
    <div class="col-sm-12 col-md-6">
        <div class="card border-0 shadow-sm">
            <div class="card-header border-bottom d-flex justify-content-between align-items-center">
                <span class="fw-semibold"><i class="bi bi-people me-2 text-primary"></i>Recent Users</span>
                <a asp-controller="User" asp-action="Index" class="btn btn-outline-primary btn-sm">View All</a>
            </div>
            <div class="card-body p-0">
                <table class="table table-hover table-striped mb-0">
                    <thead>
                        <tr>
                            <th>Name</th>
                            <th>Dept.</th>
                            <th>Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var u in (ViewBag.RecentUsers as List<ASPNetDashboard.Models.UserModel> ?? new()))
                        {
                            <tr>
                                <td>
                                    <div class="fw-semibold small">@u.Name</div>
                                    <div class="text-muted" style="font-size:.75rem;">@u.Email</div>
                                </td>
                                <td class="small text-muted">@(string.IsNullOrEmpty(u.Department) ? "—" : u.Department)</td>
                                <td>
                                    <span class="badge @(u.Status=="Active"?"bg-success":u.Status=="Inactive"?"bg-secondary":"bg-danger")">
                                        @u.Status
                                    </span>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- Recent Transactions -->
    <div class="col-sm-12 col-md-6">
        <div class="card border-0 shadow-sm">
            <div class="card-header border-bottom d-flex justify-content-between align-items-center">
                <span class="fw-semibold"><i class="bi bi-receipt me-2 text-success"></i>Recent Transactions</span>
                <a asp-controller="Transaction" asp-action="Index" class="btn btn-outline-success btn-sm">View All</a>
            </div>
            <div class="card-body p-0">
                <table class="table table-hover table-striped mb-0">
                    <thead>
                        <tr>
                            <th>Description</th>
                            <th>Type</th>
                            <th>Amount</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var t in (ViewBag.RecentTx as List<ASPNetDashboard.Models.TransactionModel> ?? new()))
                        {
                            <tr>
                                <td class="small fw-semibold">@t.Description</td>
                                <td>
                                    <span class="badge @(t.Type=="Credit"?"bg-success":"bg-danger")">
                                        @t.Type
                                    </span>
                                </td>
                                <td class="small fw-bold @(t.Type=="Credit"?"text-success":"text-danger")">
                                    @(t.Type=="Credit"?"+":"-")₱@String.Format("{0:N0}",t.Amount)
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

</div>
