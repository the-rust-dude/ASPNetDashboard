@{
    ViewData["Title"] = "Dashboard";
    var role = User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value ?? "Viewer";
    var name = User.FindFirst(System.Security.Claims.ClaimTypes.Name)?.Value ?? "User";
    decimal net = ViewBag.NetBalance;
    var weekly = (ViewBag.WeeklyCredits as List<decimal>) ?? Enumerable.Repeat(0m, 7).ToList();
    decimal weekMax = weekly.Any(v => v > 0) ? weekly.Max() : 1;
}

<!-- Page Header -->
<div class="d-flex align-items-start justify-content-between mb-4">
    <div>
        <div class="page-title">
            Good to see you, <span style="background:linear-gradient(135deg,#3b82f6,#8b5cf6);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;">@name.Split(' ')[0]</span>
        </div>
        <div class="page-sub">
            @if (role == "Admin")
            {
                <span><i class="bi bi-shield-fill me-1" style="color:#60a5fa;"></i>Admin access — full create, edit and delete capabilities enabled.</span>
            }
            else
            {
                <span><i class="bi bi-eye-fill me-1" style="color:#a78bfa;"></i>Viewer mode — read-only access to all records.</span>
            }
        </div>
    </div>
    @if (role == "Admin")
    {
        <div class="d-flex gap-2">
            <a asp-controller="User" asp-action="Create" class="btn btn-primary btn-sm">
                <i class="bi bi-person-plus-fill me-1"></i>Add User
            </a>
            <a asp-controller="Transaction" asp-action="Create" class="btn btn-outline-primary btn-sm">
                <i class="bi bi-plus-circle me-1"></i>New Transaction
            </a>
        </div>
    }
</div>

<!-- Stat Cards -->
<div class="row g-3 mb-4">
    <div class="col-sm-6 col-xl-3">
        <div class="stat-card sc-blue">
            <div class="stat-icon si-blue"><i class="bi bi-people-fill"></i></div>
            <div class="stat-label">Total Users</div>
            <div class="stat-value">@ViewBag.UserCount</div>
            <div class="stat-sub">
                <span style="color:var(--green);">@ViewBag.ActiveUsers active</span>
                &bull; @(ViewBag.UserCount - ViewBag.ActiveUsers) inactive
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="stat-card sc-green">
            <div class="stat-icon si-green"><i class="bi bi-arrow-up-circle-fill"></i></div>
            <div class="stat-label">Total Credit</div>
            <div class="stat-value" style="font-size:1.35rem;">&#8369;@String.Format("{0:N0}", ViewBag.TotalCredit)</div>
            <div class="stat-sub"><i class="bi bi-arrow-up me-1"></i>Incoming revenue</div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="stat-card sc-red">
            <div class="stat-icon si-red"><i class="bi bi-arrow-down-circle-fill"></i></div>
            <div class="stat-label">Total Debit</div>
            <div class="stat-value" style="font-size:1.35rem;">&#8369;@String.Format("{0:N0}", ViewBag.TotalDebit)</div>
            <div class="stat-sub"><i class="bi bi-arrow-down me-1"></i>Outgoing expenses</div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="stat-card @(net >= 0 ? "sc-violet" : "sc-red")">
            <div class="stat-icon @(net >= 0 ? "si-violet" : "si-red")"><i class="bi bi-wallet2"></i></div>
            <div class="stat-label">Net Balance</div>
            <div class="stat-value" style="font-size:1.35rem;">&#8369;@String.Format("{0:N0}", net)</div>
            <div class="stat-sub">
                <span class="stat-trend @(net >= 0 ? "trend-up" : "trend-down")">
                    <i class="bi bi-arrow-@(net >= 0 ? "up" : "down")"></i>
                    @(net >= 0 ? "Positive" : "Negative")
                </span>
                balance
            </div>
        </div>
    </div>
</div>

<!-- Charts + Activity row -->
<div class="row g-3 mb-3">
    <!-- Transactions count card -->
    <div class="col-md-4">
        <div class="stat-card sc-amber h-100 d-flex flex-column justify-content-between">
            <div>
                <div class="stat-icon si-amber"><i class="bi bi-receipt-cutoff"></i></div>
                <div class="stat-label">Transactions</div>
                <div class="stat-value">@ViewBag.TxCount</div>
                <div class="stat-sub">Logged records in SQLite</div>
            </div>
            <div style="margin-top:18px;">
                <!-- Mini sparkline bar chart -->
                <div style="font-size:0.65rem;color:var(--text-3);margin-bottom:6px;text-transform:uppercase;letter-spacing:.08em;">7-day credit activity</div>
                <div style="display:flex;align-items:flex-end;gap:4px;height:36px;">
                    @foreach (var v in weekly)
                    {
                        var pct = weekMax > 0 ? (double)v / (double)weekMax * 100 : 4;
                        if (pct < 4) pct = 4;
                        <div style="flex:1;background:rgba(245,158,11,@(v > 0 ? "0.55" : "0.15"));border-radius:3px 3px 0 0;height:@((int)pct)%;" title="₱@v"></div>
                    }
                </div>
            </div>
        </div>
    </div>

    <!-- Quick stats -->
    <div class="col-md-8">
        <div class="card-dark h-100">
            <div class="card-head">
                <div class="card-title-row">
                    <div class="card-dot violet"></div>
                    System Summary
                </div>
                <span style="font-size:0.72rem;color:var(--text-3);">Live data from SQLite</span>
            </div>
            <div class="card-dark-pad">
                <div class="row g-3">
                    @{
                        var items = new[]
                        {
                            new { Label="Database", Value="SQLite / EF Core 9", Icon="database-fill", Color="blue" },
                            new { Label="Auth Mode", Value="Cookie Authentication", Icon="shield-lock-fill", Color="violet" },
                            new { Label="Signed In As", Value=role, Icon="person-badge-fill", Color=(role=="Admin"?"blue":"violet") },
                            new { Label="Session Status", Value="Active", Icon="activity", Color="green" },
                        };
                    }
                    @foreach (var item in items)
                    {
                        <div class="col-6">
                            <div style="background:var(--surface);border:1px solid var(--border);border-radius:var(--r);padding:14px 16px;display:flex;align-items:center;gap:12px;">
                                <div style="width:34px;height:34px;border-radius:var(--r-sm);display:flex;align-items:center;justify-content:center;font-size:.85rem;background:var(--@item.Color-g);border:1px solid rgba(255,255,255,.06);flex-shrink:0;color:var(--@item.Color)">
                                    <i class="bi bi-@item.Icon"></i>
                                </div>
                                <div>
                                    <div style="font-size:.66rem;color:var(--text-3);text-transform:uppercase;letter-spacing:.07em;font-weight:700;">@item.Label</div>
                                    <div style="font-size:.83rem;color:var(--text);font-weight:600;margin-top:1px;">@item.Value</div>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Recent Tables -->
<div class="row g-3">
    <!-- Recent Users -->
    <div class="col-lg-6">
        <div class="card-dark">
            <div class="card-head">
                <div class="card-title-row">
                    <div class="card-dot"></div>
                    Recent Users
                </div>
                <a asp-controller="User" asp-action="Index" class="btn btn-outline-primary btn-sm">
                    View all <i class="bi bi-arrow-right ms-1"></i>
                </a>
            </div>
            <table class="table mb-0">
                <thead>
                    <tr>
                        <th>User</th>
                        <th>Dept</th>
                        <th>Status</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var u in (List<ASPNetDashboard.Models.UserModel>)ViewBag.RecentUsers)
                    {
                        <tr>
                            <td>
                                <div class="d-flex align-items-center gap-2">
                                    <div class="u-ava">@u.Name[0]</div>
                                    <div>
                                        <div class="u-name">@u.Name</div>
                                        <div class="u-email">@u.Email</div>
                                    </div>
                                </div>
                            </td>
                            <td><strong>@(string.IsNullOrEmpty(u.Department) ? "—" : u.Department)</strong></td>
                            <td>
                                <span class="badge-pill @(u.Status == "Active" ? "bp-active" : u.Status == "Inactive" ? "bp-inactive" : "bp-suspend")">
                                    @u.Status
                                </span>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <!-- Recent Transactions -->
    <div class="col-lg-6">
        <div class="card-dark">
            <div class="card-head">
                <div class="card-title-row">
                    <div class="card-dot green"></div>
                    Recent Transactions
                </div>
                <a asp-controller="Transaction" asp-action="Index" class="btn btn-outline-primary btn-sm">
                    View all <i class="bi bi-arrow-right ms-1"></i>
                </a>
            </div>
            <table class="table mb-0">
                <thead>
                    <tr>
                        <th>Description</th>
                        <th>Type</th>
                        <th>Amount</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var t in (List<ASPNetDashboard.Models.TransactionModel>)ViewBag.RecentTx)
                    {
                        <tr>
                            <td>
                                <strong style="font-size:.84rem;display:block;max-width:160px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">@t.Description</strong>
                                <span style="font-size:.7rem;color:var(--text-3);">@t.Reference &bull; @t.Date.ToString("MMM dd")</span>
                            </td>
                            <td>
                                <span class="badge-pill @(t.Type=="Credit" ? "bp-credit" : "bp-debit")">
                                    <i class="bi bi-arrow-@(t.Type=="Credit"?"up":"down")"></i>@t.Type
                                </span>
                            </td>
                            <td>
                                <strong style="font-size:.88rem;color:@(t.Type=="Credit" ? "var(--green)" : "var(--red)");">
                                    @(t.Type=="Credit"?"+":"-")&#8369;@String.Format("{0:N0}",t.Amount)
                                </strong>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
